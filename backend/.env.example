# Backend Environment Variables
# Copy file ini ke .env dan isi nilainya

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/marketplace_ai"

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Security ──────────────────────────────────────────────────────────────────
# Minimal 32 karakter acak yang kuat untuk enkripsi cookies AES-256-GCM
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_ENCRYPTION_KEY="GANTI_DENGAN_KEY_ACAK_MINIMAL_32_KARAKTER"

# ─── Scraper ───────────────────────────────────────────────────────────────────
# Path ke Python executable di virtual environment scraper
PYTHON_PATH="./scraper/venv/bin/python"
# Path ke scraper script
SCRAPER_SCRIPT_PATH="./scraper/scraper.py"

# ─── Frontend ──────────────────────────────────────────────────────────────────
# Origin yang diizinkan untuk CORS
FRONTEND_URL="http://localhost:5173"
